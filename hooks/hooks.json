{
  "description": "devloop gates — TDD RED-skip gate + heal-scoped readonly path guard (self-heal safety).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/scripts/tdd-gate.mjs"],
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/scripts/heal-guard.mjs"],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
